USE_REAL_LLM_PLANNER=true
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ADK pipeline (POST /adk/plan and /adk/simulate)
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
ADK_MODEL=gemini-2.5-flash

# Optional — enables live GCP TPU v5e pricing lookups via Cloud Billing Catalog API.
# Without this, the pricing tool falls back to a dated snapshot value (documented
# in README.md under "Known Limitations").
# Setup: enable the Cloud Billing API on a Google Cloud project, then create a
# restricted API key (restrict to "Cloud Billing API" only).
GOOGLE_CLOUD_API_KEY=your_gcp_billing_api_key_here
